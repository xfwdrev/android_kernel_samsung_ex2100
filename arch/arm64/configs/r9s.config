# CONFIG_CAMERA_CIS_GH1_OBJ is not set
# CONFIG_CAMERA_CIS_GW2_OBJ is not set
CONFIG_CAMERA_CIS_HI847_OBJ=m
CONFIG_CAMERA_CIS_2LD_OBJ=m
# CONFIG_CAMERA_CIS_HM1_OBJ is not set
# CONFIG_CAMERA_CIS_HM3_OBJ is not set
CONFIG_CAMERA_CIS_IMX258_OBJ=m
# CONFIG_CAMERA_CIS_IMX563_OBJ is not set
CONFIG_CAMERA_CIS_IMX616_OBJ=m
CONFIG_CAMERA_CIS_HI1336_OBJ=m
CONFIG_CAMERA_FLASH_KTD2692_OBJ=m

# CONFIG_EXYNOS_DECON_LCD_COPR is not set
# CONFIG_SUPPORT_HMD is not set
# CONFIG_EXTEND_LIVE_CLOCK is not set
# CONFIG_SUPPORT_DISPLAY_PROFILER is not set
# CONFIG_SUPPORT_DDI_FLASH is not set
# CONFIG_SUPPORT_POC_FLASH is not set
# CONFIG_SUPPORT_MAFPC is not set
# CONFIG_SUPPORT_POC_SPI is not set
# CONFIG_SUPPORT_GM2_FLASH is not set
CONFIG_SUPPORT_MASK_LAYER=y
# CONFIG_SUPPORT_BRIGHTDOT_TEST is not set
# CONFIG_EVASION_DISP_DET is not set
CONFIG_SUPPORT_TIG=y
CONFIG_EXYNOS_DECON_LCD_S6E3FAB=m
CONFIG_EXYNOS_DECON_LCD_S6E3HAB=m
# CONFIG_EXYNOS_DECON_LCD_S6E3HAD is not set
CONFIG_EXYNOS_DECON_LCD_EA8082=m
CONFIG_EXYNOS_DECON_LCD_S6E3FC3=m

CONFIG_SND_SOC_SAMSUNG_ABOX_CHANGE_RMEM_SIZE=m

CONFIG_LEDS_KTD2692=m

# CONFIG_USE_LLC_LOG is not set
# CONFIG_USE_PPC_LOG is not set
CONFIG_DEBUG_SNAPSHOT_LOG_ITEM_SIZE=128

# CONFIG_SENSORS is not set
# CONFIG_SENSORS_SX9364 is not set
CONFIG_SENSORS_ISG5320A=m
# CONFIG_SENSORS_ISG5320A_O1S is not set
CONFIG_SENSORS_FINGERPRINT_NORMALSPI=y
# CONFIG_SENSORS_QBT2000 is not set
CONFIG_SENSORS_GW9558X=m
# CONFIG_SENSORS_SSP_UNBOUND is not set
CONFIG_SENSORS_SSP_R9S=y
CONFIG_SENSORS_FLIP_COVER_DETECTOR=y
# CONFIG_TOUCHSCREEN_SLSI is not set
CONFIG_TOUCHSCREEN_SYNAPTICS=m
# CONFIG_SENSORS_VL53L5 is not set
# CONFIG_SENSORS_VL53L5_SUPPORT_UAPI is not set
# CONFIG_SENSORS_VL53L5_SUPPORT_KERNEL_INTERFACE is not set
# CONFIG_SENSORS_VL53L5_SLSI is not set
# CONFIG_SENSORS_TSL2510 is not set
CONFIG_SENSORS_FLICKER_SELF_TEST=m
CONFIG_SENSORS_STK3A8X=m
CONFIG_SENSORS_SUPPORT_SLSI=y
CONFIG_HALL_NOTIFIER=m
CONFIG_HALL_LOGICAL=m

