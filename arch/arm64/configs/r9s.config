# Config file for r9s (Galaxy S21 FE 5G)
# This is merged with exynos2100_defconfig on build

CONFIG_MODEL_R9S=y

CONFIG_RBIN=y
CONFIG_ION_RBIN_HEAP=y

CONFIG_SEC_NFC_LOGGER_ADD_ACPM_LOG=y
CONFIG_SEC_NFC_LOGGER_RTC_REG_ADDR=0x15920090

CONFIG_USB_NET_AQC111=y
CONFIG_BCM4375=m
# CONFIG_BCM4389 is not set
# CONFIG_WLAN_BCM4375_ADVANCED_FEATURES is not set
CONFIG_WLAN_SOFTAP_HE_ENABLE=y

# CONFIG_MFD_S2MPB02 is not set

CONFIG_CAMERA_OTPROM_SUPPORT_REAR=m
CONFIG_FLASH_CURRENT_CHANGE_SUPPORT=y
# CONFIG_CAMERA_USU_V01 is not set
# CONFIG_CAMERA_USU_V02 is not set
# CONFIG_CAMERA_USU_V03 is not set
CONFIG_CAMERA_RSU_V09=y
